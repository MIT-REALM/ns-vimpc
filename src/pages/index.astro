		column-gap: 1em;
		flex-wrap: wrap;
		justify-content: space-around;

		font-size: 1.2em;
	}

	.full-width {
		width: 100%;
	}

	.display-eq {
		font-size: large;
	}

	@media screen and (min-width: 1024px) {
		.display-eq {
			font-size: xx-large;
		}
	}

	.section-body > p {
		align-self: flex-start;
	}

	.teaser {
		font-family: "Google Sans", sans-serif;
		display: flex;
		align-items: center;
		gap: 1em;
		flex-wrap: wrap;
	}

