	}

	section {
		font-family: "Open Sans", sans-serif;
	}

	iframe {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;

		border: 0;
	}

	.avoidwrap {
		display: inline-block;
	}

	#unicycle-vid-col {
		width: 100.0%
	}

	#unicycle-txt-col {
		width: 100.0%;
	}

	.section-title {
		font-weight: 600;
		line-height: 1.125;

		font-size: 1.6rem;
	}

